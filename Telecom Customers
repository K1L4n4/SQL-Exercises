--Query #1. Write a query that selects the customer id of all the customers who are subscribed to Cell Phone service products.

--Step 1: Write the inner query
SELECT product_id
FROM products
WHERE product_type = 'Cell Phone Service'
;

--Step 2: Write the outer query
SELECT customer_id
FROM customer_subscriptions
WHERE product_id IN ('4', '5', '6')
;


--Step 3: Combine the queries
SELECT customer_id
FROM customer_subscriptions
WHERE product_id IN (SELECT product_id 
FROM products 
WHERE product_type = 'Cell Phone Service')
;

--Query 2. Write a query that will select the email address of all the customers with the "Internet" product type.

SELECT email
FROM customer_subscriptions
WHERE product_id IN (SELECT product_id
FROM products
WHERE product_type = 'Internet')
;

--Query 3. Write a query that will select the emails of all customers who are paying more than the average price for internet.

--Average Monthly Price
SELECT AVG(monthly_price)
FROM products
;

--Customers paying more than average
SELECT product_id
FROM products
WHERE monthly_price > (SELECT AVG(monthly_price)
FROM products)
;

--Emails from Customers paying more than average
SELECT email
FROM customer_subscriptions
WHERE price > (SELECT AVG(monthly_price) FROM products WHERE product_type='Internet');




